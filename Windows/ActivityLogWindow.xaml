<Window x:Class="CyberChatbotApplication.Windows.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 CYBA Activity Log"
        Height="500" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="15,10" Margin="0,0,0,12">
			<StackPanel>
				<TextBlock Text="📊 Activity Log" Foreground="#00B4D8" FontSize="18" FontWeight="Bold"/>
				<TextBlock x:Name="SummaryText" Text="Showing recent actions"
                           Foreground="#8B949E" FontSize="11" Margin="0,4,0,0"/>
			</StackPanel>
		</Border>

		<!-- Log List -->
		<Border Grid.Row="1" Background="#161B22" CornerRadius="8" Padding="5"
                BorderBrush="#30363D" BorderThickness="1">
			<ListView x:Name="LogListView" Background="Transparent" BorderThickness="0"
                      Foreground="White" FontSize="12" SelectionMode="Single">
				<ListView.View>
					<GridView>
						<GridViewColumn Header="#" Width="30" DisplayMemberBinding="{Binding Index}"/>
						<GridViewColumn Header="Time" Width="110" DisplayMemberBinding="{Binding Time}"/>
						<GridViewColumn Header="Action" Width="180" DisplayMemberBinding="{Binding Action}"/>
						<GridViewColumn Header="Details" Width="230" DisplayMemberBinding="{Binding Details}"/>
					</GridView>
				</ListView.View>
				<ListView.Resources>
					<Style TargetType="ListViewItem">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="Foreground" Value="White"/>
						<Setter Property="Padding" Value="4,5"/>
					</Style>
				</ListView.Resources>
			</ListView>
		</Border>

		<!-- Controls -->
		<Grid Grid.Row="2" Margin="0,12,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<Button x:Name="ShowMoreBtn" Content="Show More" Grid.Column="0"
                    Background="#1F6F8B" Foreground="White" BorderThickness="0"
                    Padding="12,6" FontSize="12" Cursor="Hand"
                    Click="ShowMoreBtn_Click" Margin="0,0,8,0"/>
			<TextBlock x:Name="CountLabel" Grid.Column="1"
                       Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
			<Button Content="🔄 Refresh" Grid.Column="2"
                    Background="#30363D" Foreground="White" BorderThickness="0"
                    Padding="12,6" FontSize="12" Cursor="Hand"
                    Click="RefreshBtn_Click" Margin="0,0,8,0"/>
			<Button Content="Close" Grid.Column="3"
                    Background="#30363D" Foreground="White" BorderThickness="0"
                    Padding="12,6" FontSize="12" Cursor="Hand"
                    Click="CloseBtn_Click"/>
		</Grid>
	</Grid>
</Window>


<Window x:Class="CyberChatbotApplication.Windows.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 CYBA Cybersecurity Quiz"
        Height="560" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="15,10" Margin="0,0,0,15">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Text="🎮 Cybersecurity Knowledge Quiz"
                           Foreground="#00B4D8" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
				<StackPanel Grid.Column="1" Orientation="Horizontal">
					<TextBlock Text="Score: " Foreground="#8B949E" VerticalAlignment="Center" FontSize="13"/>
					<TextBlock x:Name="ScoreLabel" Text="0" Foreground="#FFD700" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
					<TextBlock Text=" / " Foreground="#8B949E" VerticalAlignment="Center" FontSize="13"/>
					<TextBlock x:Name="TotalLabel" Text="0" Foreground="#8B949E" FontSize="13" VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Progress Bar -->
		<Grid Grid.Row="1" Margin="0,0,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<TextBlock x:Name="QuestionCountLabel" Text="Question 1 of 10"
                       Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
			<ProgressBar x:Name="ProgressBar" Grid.Column="1" Height="8"
                         Background="#30363D" Foreground="#00B4D8"
                         Minimum="0" Maximum="10" Value="0"/>
		</Grid>

		<!-- Question -->
		<Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="15" Margin="0,0,0,12"
                BorderBrush="#30363D" BorderThickness="1">
			<TextBlock x:Name="QuestionText"
                       Foreground="#E6EDF3" FontSize="15" FontWeight="SemiBold"
                       TextWrapping="Wrap" LineHeight="22"/>
		</Border>

		<!-- Answer Options -->
		<StackPanel x:Name="OptionsPanel" Grid.Row="3" Margin="0,0,0,12"/>

		<!-- Feedback / Result Area -->
		<Border Grid.Row="4" x:Name="FeedbackBorder" Background="#1A2A1A" CornerRadius="8"
                Padding="12" Visibility="Collapsed" Margin="0,0,0,8"
                BorderBrush="#1F8B4C" BorderThickness="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<TextBlock x:Name="FeedbackText" Foreground="#E6EDF3"
                           TextWrapping="Wrap" FontSize="13" Margin="0,0,0,10"/>
				<Button x:Name="NextBtn" Grid.Row="1" Content="Next Question ➡️"
                        Background="#1F6F8B" Foreground="White" BorderThickness="0"
                        Padding="15,8" FontSize="13" FontWeight="Bold"
                        Cursor="Hand" HorizontalAlignment="Right"
                        Click="NextBtn_Click"/>
			</Grid>
		</Border>
	</Grid>
</Window>

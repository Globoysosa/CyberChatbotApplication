<Window x:Class="CyberChatbotApplication.Windows.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBA Task Assistant"
        Height="620" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

	<Window.Resources>
		<Style TargetType="Button" x:Key="ActionBtn">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="FontSize" Value="12"/>
		</Style>
	</Window.Resources>

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="15,10" Margin="0,0,0,12">
			<StackPanel>
				<TextBlock Text="Cybersecurity Task Assistant"
                           Foreground="#00B4D8" FontSize="18" FontWeight="Bold"/>
				<TextBlock Text="Manage your cybersecurity to-do list with optional reminders."
                           Foreground="#8B949E" FontSize="11" Margin="0,4,0,0"/>
			</StackPanel>
		</Border>

		<Border Grid.Row="1" Background="#161B22" CornerRadius="8" Padding="15" Margin="0,0,0,12"
                BorderBrush="#30363D" BorderThickness="1">
			<StackPanel>
				<TextBlock Text="Add New Task" Foreground="#00B4D8" FontWeight="Bold" FontSize="13" Margin="0,0,0,10"/>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="8"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Task Title:" Foreground="#8B949E" FontSize="11" Margin="0,0,0,4"/>

					<TextBox x:Name="TitleBox" Grid.Row="1" Grid.Column="0"
                             Background="#0D1117" Foreground="#E6EDF3" BorderBrush="#30363D"
                             BorderThickness="1" Padding="8,6" FontSize="13" Margin="0,0,8,0"/>

					<Button x:Name="AddTaskBtn" Grid.Row="1" Grid.Column="1"
                            Content="Add Task" Style="{StaticResource ActionBtn}"
                            Background="#1F8B4C" Width="110" Click="AddTaskBtn_Click"/>

					<TextBox x:Name="DescBox" Grid.Row="3" Grid.Column="0"
                             Background="#0D1117" Foreground="#666666" BorderBrush="#30363D"
                             BorderThickness="1" Padding="8,6" FontSize="12"
                             Text="Description (optional)"
                             GotFocus="DescBox_GotFocus" Margin="0,0,8,0"/>

					<DatePicker x:Name="ReminderDate" Grid.Row="3" Grid.Column="1"
                                Foreground="#E6EDF3" BorderBrush="#30363D"
                                SelectedDateFormat="Short"
                                ToolTip="Optional reminder date"/>
				</Grid>
			</StackPanel>
		</Border>

		<Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="5"
                BorderBrush="#30363D" BorderThickness="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<Grid Grid.Row="0" Margin="10,8,10,5">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="Your Tasks" Foreground="#00B4D8" FontWeight="Bold" FontSize="13"/>
					<Button Grid.Column="1" Content="Refresh" Style="{StaticResource ActionBtn}"
                            Background="#30363D" Click="RefreshBtn_Click"/>
				</Grid>

				<ListView x:Name="TaskListView" Grid.Row="1"
                          Background="Transparent" BorderThickness="0"
                          Foreground="White" FontSize="13"
                          SelectionMode="Single">
					<ListView.View>
						<GridView>
							<GridViewColumn Header="Status" Width="65">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding StatusIcon}" HorizontalAlignment="Center"/>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>
							<GridViewColumn Header="Title" Width="200" DisplayMemberBinding="{Binding Title}"/>
							<GridViewColumn Header="Description" Width="170" DisplayMemberBinding="{Binding Description}"/>
							<GridViewColumn Header="Reminder" Width="130">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding ReminderText}" Foreground="#00B4D8"/>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>
						</GridView>
					</ListView.View>
					<ListView.Resources>
						<Style TargetType="ListViewItem">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="Padding" Value="4,6"/>
						</Style>
					</ListView.Resources>
				</ListView>
			</Grid>
		</Border>

		<StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
			<Button x:Name="CompleteBtn" Content="Mark Complete" Style="{StaticResource ActionBtn}"
                    Background="#1F6F8B" Margin="0,0,8,0" Click="CompleteBtn_Click"/>
			<Button x:Name="DeleteBtn" Content="Delete Task" Style="{StaticResource ActionBtn}"
                    Background="#8B1A1A" Margin="0,0,8,0" Click="DeleteBtn_Click"/>
			<Button x:Name="CloseBtn" Content="Close" Style="{StaticResource ActionBtn}"
                    Background="#30363D" Click="CloseBtn_Click"/>
		</StackPanel>
	</Grid>
</Window>
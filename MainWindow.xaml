п»ҝ<Window x:Class="CyberChatbotApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBA - Cybersecurity Awareness Assistant" 
        Height="650" Width="850" 
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Header - Fixed Size -->
        <Border Grid.Row="0" Background="#1E3A5F" BorderBrush="#00B4D8" BorderThickness="0,0,0,2">
            <StackPanel Margin="10" HorizontalAlignment="Center">
                <TextBlock Text="   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— " 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="  в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="  в–Ҳв–Ҳв•‘       в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="   в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00B4D8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="          CYBA - CYBER AWARENESS BOT" 
                           FontFamily="Consolas" 
                           FontSize="11" 
                           Foreground="#00B4D8" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Title Bar -->
        <Border Grid.Row="1" Background="#161B22" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="рҹӣЎпёҸ CYBERSECURITY AWARENESS ASSISTANT" 
                           Foreground="#00B4D8" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button x:Name="VoiceButton" 
                        Content="рҹ”Ҡ Play Greeting" 
                        Width="110" 
                        Margin="20,0,0,0"
                        Background="#1F6F8B" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="VoiceButton_Click"/>
                <Button x:Name="ConsoleButton" 
                        Content="рҹ’» Switch to Console" 
                        Width="130" 
                        Margin="10,0,0,0"
                        Background="#30363D" 
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ConsoleButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto"
                      Background="#0D1117">
            <StackPanel x:Name="ChatPanel" Margin="10" Orientation="Vertical"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#161B22" Padding="10" BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput" 
                         Grid.Column="0"
                         Background="#0D1117"
                         Foreground="#E6EDF3"
                         BorderBrush="#30363D"
                         BorderThickness="1"
                         FontSize="13"
                         Padding="10"
                         KeyDown="UserInput_KeyDown"
                         TextWrapping="Wrap"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="SEND" 
                        Width="70" 
                        Height="35"
                        Margin="10,0,0,0"
                        Background="#1F6F8B" 
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>